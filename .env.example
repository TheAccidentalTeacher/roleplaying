# ===========================================
# AI RPG — Environment Variables
# ===========================================
# Copy this file to .env and fill in your real keys.
# NEVER commit .env — it is gitignored.

# ===========================================
# 🤖 CORE AI APIs (required)
# ===========================================
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ===========================================
# 🎨 AI IMAGE GENERATION APIs (optional)
# ===========================================
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
STABILITY_AI_API_KEY=your_stability_ai_api_key_here
REPLICATE_API_TOKEN=your_replicate_api_token_here

# ===========================================
# 📸 STOCK PHOTO / IMAGE APIs (optional)
# ===========================================
PEXELS_API_KEY=your_pexels_api_key_here
PIXABAY_API_KEY=your_pixabay_api_key_here
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
UNSPLASH_SECRET_KEY=your_unsplash_secret_key_here
GIPHY_API_KEY=your_giphy_api_key_here

# ===========================================
# 🔍 SEARCH / DATA APIs (optional)
# ===========================================
TAVILY_API_KEY=your_tavily_api_key_here
SERPAPI_KEY=your_serpapi_key_here
NEWS_API_KEY=your_news_api_key_here

# ===========================================
# 📱 SOCIAL / MEDIA APIs (optional)
# ===========================================
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
YOUTUBE_API_KEY=your_youtube_api_key_here

# ===========================================
# 🎨 ILLUSTRATION APIs (optional)
# ===========================================
FREEPIK_API_KEY=your_freepik_api_key_here
FREEPIK_WEBHOOK_SECRET=your_freepik_webhook_secret_here
VECTEEZY_ACCOUNT_ID=your_vecteezy_account_id_here
VECTEEZY_SECRET_KEY=your_vecteezy_secret_key_here

# ===========================================
# 🔊 TEXT-TO-SPEECH (optional)
# ===========================================
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Azure Speech TTS — 500K chars/month free tier
# Get key at: https://portal.azure.com → Cognitive Services → Speech
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=westus

# ===========================================
# ⚡ GROQ (optional — Oracle, Eval, Prompt Wizard)
# ===========================================
# Free tier available at https://console.groq.com
# Used by: /api/oracle, /api/eval-message, /api/prompt-wizard
GROQ_API_KEY=your_groq_api_key_here

# ===========================================
# ☁️ CLOUDINARY (optional — CDN for generated images)
# ===========================================
# Free tier: 25GB storage, 25GB bandwidth/month
# Get URL at https://cloudinary.com → Dashboard → API Keys
# Format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# ===========================================
# 🔊 OBSERVABILITY (optional)
# ===========================================
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ===========================================
# 🎵 AUDIO (optional)
# ===========================================
FREESOUND_API_KEY=your_freesound_api_key_here

# ===========================================
# 🗄️ SUPABASE (required for database)
# ===========================================
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here
